# ============================================================
# Αντίγραψε αυτό το αρχείο σε .env και συμπλήρωσε τις τιμές
# cp .env.example .env
# ============================================================

# Gmail που θα στέλνει τα emails (π.χ. το email της Μαρίας)
EMAIL_USER=maria@gmail.com

# Gmail App Password (ΟΧΙ ο κωδικός του Gmail — δες οδηγίες παρακάτω)
EMAIL_PASS=abcd efgh ijkl mnop

# Email που θα λαμβάνει τα μηνύματα (συνήθως ίδιο με EMAIL_USER)
EMAIL_TO=maria@gmail.com

# URL της σελίδας (για το auto-reply email)
SITE_URL=https://maria-portfolio.up.railway.app

# Port (αφήνεις ως έχει — το Railway το ορίζει αυτόματα)
PORT=3000

# ============================================================
# Πώς να φτιάξεις Gmail App Password:
# 1. Πήγαινε στο myaccount.google.com
# 2. Security → 2-Step Verification (ενεργοποίησέ το αν δεν είναι)
# 3. Security → App Passwords
# 4. Select app: Mail | Select device: Other → "Portfolio"
# 5. Αντίγραψε τον 16-ψήφιο κωδικό που εμφανίζεται
# ============================================================
