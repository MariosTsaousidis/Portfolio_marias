# ============================================================
# Αντίγραψε αυτό το αρχείο σε .env και συμπλήρωσε τις τιμές
# ============================================================

# Brevo login email (το email που έχεις εγγραφεί στο brevo.com)
EMAIL_USER=maria@gmail.com

# Brevo SMTP Key — ΟΧΙ ο κωδικός σου, ειδικό key από το Brevo dashboard
# (Brevo → Settings → SMTP & API → SMTP → "Generate a new SMTP Key")
EMAIL_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx

# Email που θα λαμβάνει τα μηνύματα (συνήθως ίδιο με EMAIL_USER)
EMAIL_TO=maria@gmail.com

# URL της δημοσιευμένης σελίδας (για το auto-reply email)
SITE_URL=https://maria-portfolio.up.railway.app

# Port (το Railway το ορίζει αυτόματα — μην το αλλάξεις)
PORT=3000
